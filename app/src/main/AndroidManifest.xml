<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" /> <!-- Phone number reading (optional, for auto OTP detection) -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" /> <!-- Required tag for SMS permission -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:name=".PawConnectApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AuthApp">
        <activity
            android:name=".ui.Chat.InboxActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Chat.ChatActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Appointments.VetAppointmentsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Appointments.MyAppointmentsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Appointments.BookAppointmentActivity"
            android:exported="false" />
        <activity
            android:name=".ui.discover.DiscoverActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AuthApp">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.WelcomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SignUpActivity"
            android:exported="false" />
        <activity
            android:name=".ui.OtpActivity"
            android:exported="false" />
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.DashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pets.MyPetsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pets.AddPetActivity"
            android:exported="false" />
        <activity
            android:name=".ui.pets.PetDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Vets.FindVetsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Vets.VetDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.Vets.VetProfileSetupActivity"
            android:exported="false" />
    </application>

</manifest>